TAG		?=1.12.4
LATEST		?=false

RELEASE_URL=http://cloud.loongnix.cn/releases/loongarch64abi1/influxdata/influxdb/1.12.4/influxdb-bins-1.12.4.tar.gz
IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):$(TAG)
LATEST_IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):latest

default: image

release:
	wget -q $(RELEASE_URL)

image: release
	docker build \
		-t $(IMAGE) \
                -f Dockerfile \
		.

push:
	docker push $(IMAGE)
	#latest image
	@if [ $(LATEST) = "true" ]; \
		then \
		docker tag $(IMAGE) $(LATEST_IMAGE); \
		docker push $(LATEST_IMAGE); \
	fi
