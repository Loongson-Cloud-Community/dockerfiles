# This file is generated by the template.

REGISTRY	?=cr.loongnix.cn
ORGANIZATION	?=apache
REPOSITORY	?=apisix-runtime-deb
TAG		?=1.3.3
LATEST		?=false
APISIX_VER      ?=3.9.0

IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):$(TAG)
LATEST_IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):latest
SOURCE_URL=https://github.com/api7/apisix-build-tools.git

default: image

.PHONY: src image push clean

src:
	git clone --quiet -b apisix/$(APISIX_VER) --single-branch $(SOURCE_URL)

image: src
	pushd apisix-build-tools && \
        git apply ../add-loong64abi1-support.patch && \
	make build-apisix-runtime-deb checkout=$(APISIX_VER) version=$(APISIX_VER) runtime_version=$(TAG) http_proxy=$(http_proxy) https_proxy=$(https_proxy) no_proxy=$(no_proxy) && \
        popd

push:
	docker push $(IMAGE)
	#latest image
	@if [ $(LATEST) = "true" ]; \
		then \
		docker tag $(IMAGE) $(LATEST_IMAGE); \
		docker push $(LATEST_IMAGE); \
	fi

clean:
	rm -rf dify-plugin-daemon
