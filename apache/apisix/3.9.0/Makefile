REGISTRY        ?=cr.loongnix.cn
ORGANIZATION    ?=apache
REPOSITORY      ?=apisix
TAG             ?=3.9.0
LATEST          ?=false

IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):$(TAG)
LATEST_IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):latest

default: image

image:
	docker build -t $(IMAGE) .

push:
	docker push $(IMAGE)
	#latest image
	@if [ $(LATEST) = "true" ]; \
                then \
                docker tag $(IMAGE) $(LATEST_IMAGE); \
                docker push $(LATEST_IMAGE); \
        fi

